{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": false,
			"defaultPalette": false,
			"palette": [
				{ "name": "Azul principal", "slug": "azul-principal", "color": "#244896" },
				{ "name": "Amarelo", "slug": "amarelo", "color": "#F6E566" },
				{ "name": "Fundo principal", "slug": "fundo-principal", "color": "#FFFDF0" },
				{ "name": "Verde", "slug": "verde", "color": "#6AA84F" },
				{ "name": "Azul claro", "slug": "azul-claro", "color": "#88A5DE" },
				{ "name": "Azul medio", "slug": "azul-medio", "color": "#426EC6" },
				{ "name": "Verde claro", "slug": "verde-claro", "color": "#C1EFAC" },
				{ "name": "Grafite", "slug": "grafite", "color": "#1A2238" },
				{ "name": "Cinza suave", "slug": "cinza-suave", "color": "#E5E1CC" },
				{ "name": "Branco", "slug": "branco", "color": "#FFFFFF" }
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1180px"
		},
		"spacing": {
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem"
			},
			"units": [ "px", "rem", "%", "vh", "vw" ]
		},
		"typography": {
			"customFontSize": false,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"name": "Anton",
					"slug": "anton",
					"fontFamily": "\"Anton\", Impact, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Anton",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/anton/anton-regular-latin.woff2" ]
						}
					]
				},
				{
					"name": "Roboto",
					"slug": "roboto",
					"fontFamily": "\"Roboto\", Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Roboto",
							"fontStyle": "normal",
							"fontWeight": "300",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/roboto/roboto-latin-variable.woff2" ]
						},
						{
							"fontFamily": "Roboto",
							"fontStyle": "normal",
							"fontWeight": "500",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/roboto/roboto-latin-variable.woff2" ]
						},
						{
							"fontFamily": "Roboto",
							"fontStyle": "normal",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/roboto/roboto-latin-variable.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "name": "Pequeno", "slug": "small", "size": "0.875rem" },
				{ "name": "Base", "slug": "medium", "size": "1rem" },
				{ "name": "Grande", "slug": "large", "size": "1.25rem" },
				{ "name": "Titulo", "slug": "x-large", "size": "2.25rem" },
				{ "name": "Chamada", "slug": "xx-large", "size": "3.5rem" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|fundo-principal",
			"text": "var:preset|color|grafite"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|roboto",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "300",
			"lineHeight": "1.7",
			"letterSpacing": "0"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "6px"
				},
				"color": {
					"background": "var:preset|color|azul-principal",
					"text": "var:preset|color|branco"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|roboto",
					"fontWeight": "500"
				}
			},
			"caption": {
				"color": {
					"text": "var:preset|color|grafite"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"lineHeight": "1.5"
				}
			},
			"heading": {
				"color": {
					"text": "var:preset|color|azul-principal"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|anton",
					"fontWeight": "400",
					"lineHeight": "1.05",
					"letterSpacing": "0",
					"textTransform": "uppercase"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|azul-principal"
				},
				"typography": {
					"textDecoration": "underline"
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var:preset|font-family|roboto",
					"fontWeight": "500"
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Cabeçalho", "area": "header" },
		{ "name": "footer", "title": "Rodapé", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "front-page", "title": "Página inicial" }
	]
}
